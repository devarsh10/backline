---
import type { EquipmentItem } from '../data/equipment';

interface Props {
  item: EquipmentItem;
  compact?: boolean;
}

const { item, compact = false } = Astro.props;
---

<div class={`gear-card ${compact ? 'gear-card--compact' : ''}`}>
  <!-- Image -->
  <a href={`/equipment/${item.category}/${item.slug}`} class="gear-card-img-link" tabindex="-1" aria-hidden="true">
    <div class="gear-card-img">
      {item.image ? (
        <img src={item.image} alt={item.name} loading="lazy" class="gear-card-photo" />
      ) : (
        <div class="gear-card-img-placeholder" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.2">
            <path d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/>
          </svg>
        </div>
      )}
      {item.featured && <span class="gear-featured-badge">Featured</span>}
    </div>
  </a>

  <!-- Content -->
  <div class="gear-card-body">
    <div class="gear-card-meta">
      <span class="caption-mono gear-brand">{item.brand}</span>
      <span class="gear-sub">{item.subcategory}</span>
    </div>
    <a href={`/equipment/${item.category}/${item.slug}`} class="gear-card-name-link">
      <h3 class="gear-card-name">{item.name}</h3>
    </a>
    <div class="gear-card-footer">
      <span class="gear-price">₹{item.pricePerDay.toLocaleString('en-IN')}<span class="gear-price-unit">/day</span></span>
      <button
        class="add-to-cart-btn"
        data-slug={item.slug}
        data-name={item.name}
        data-brand={item.brand}
        data-category={item.category}
        data-price={item.pricePerDay}
        aria-label={`Add ${item.name} to cart`}
      >
        + Add
      </button>
    </div>
  </div>
</div>

<style>
  .gear-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-canvas);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-hairline);
    overflow: hidden;
    transition: box-shadow 0.2s, border-color 0.2s;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
  }
  .gear-card:hover {
    border-color: var(--color-hairline-strong);
    box-shadow: 0 0 0 1px rgba(0,0,0,0.06), 0 4px 16px -4px rgba(0,0,0,0.10);
  }
  .gear-card-img-link { display: block; }
  .gear-card-img {
    background-color: var(--color-canvas-soft-2);
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--color-hairline);
    overflow: hidden;
    position: relative;
  }
  .gear-card--compact .gear-card-img { aspect-ratio: 16/9; }
  .gear-card-photo { width: 100%; height: 100%; object-fit: cover; }
  .gear-card-img-placeholder { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; }
  .gear-featured-badge {
    position: absolute; top: 8px; left: 8px;
    background-color: var(--color-ink); color: var(--color-on-primary);
    font-size: 10px; font-weight: 500; padding: 2px 8px;
    border-radius: var(--radius-full);
  }
  .gear-card-body {
    padding: 14px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 4px;
  }
  .gear-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
  }
  .gear-brand { color: var(--color-mute); }
  .gear-sub { font-size: 11px; color: var(--color-mute); text-align: right; }
  .gear-card-name-link { text-decoration: none; color: inherit; }
  .gear-card-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin: 2px 0 6px;
  }
  .gear-card--compact .gear-card-name { font-size: 13px; }
  .gear-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 10px;
    border-top: 1px solid var(--color-hairline);
    gap: 8px;
  }
  .gear-price {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.02em;
  }
  .gear-price-unit {
    font-size: 12px;
    font-weight: 400;
    color: var(--color-mute);
    margin-left: 1px;
  }
  .add-to-cart-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-ink);
    color: var(--color-on-primary);
    font-size: 12px;
    font-weight: 500;
    padding: 5px 12px;
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }
  .add-to-cart-btn:hover { opacity: 0.85; }
  .add-to-cart-btn.added {
    background-color: var(--color-accent-deep);
  }
</style>

<script>
  import { addToCart, updateCartBadge } from '../scripts/cart';

  document.querySelectorAll<HTMLButtonElement>('.add-to-cart-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      addToCart({
        slug: btn.dataset.slug!,
        name: btn.dataset.name!,
        brand: btn.dataset.brand!,
        category: btn.dataset.category!,
        pricePerDay: Number(btn.dataset.price),
      });
      btn.textContent = '✓ Added';
      btn.classList.add('added');
      setTimeout(() => {
        btn.textContent = '+ Add';
        btn.classList.remove('added');
      }, 1400);
      updateCartBadge();
    });
  });
</script>
