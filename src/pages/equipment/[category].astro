---
import Layout from '../../layouts/Layout.astro';
import { categories, getEquipmentByCategory, getCategoryBySlug } from '../../data/equipment';
import type { EquipmentItem } from '../../data/equipment';

export async function getStaticPaths() {
  return categories.map(cat => ({
    params: { category: cat.slug },
  }));
}

const { category } = Astro.params;
const cat = getCategoryBySlug(category!);
const allItems = getEquipmentByCategory(category!).filter(i => i.available);

if (!cat) return Astro.redirect('/equipment');

const isDrums = category === 'drums';
const items      = isDrums ? allItems.filter(i => i.subcategory !== 'Cymbals') : allItems;
const cymbalItems = isDrums ? allItems.filter(i => i.subcategory === 'Cymbals') : [];

// Group by brand, sorted alphabetically
const brandGroups = items.reduce((acc, item) => {
  if (!acc[item.brand]) acc[item.brand] = [];
  acc[item.brand].push(item);
  return acc;
}, {} as Record<string, typeof items>);
const brands = Object.keys(brandGroups).sort();

const heroImages: Record<string, string> = {
  drums:      '/images/drum&cymbals.jpg',
  guitars:    '/images/guitar&bass-guitar.jpg',
  amplifiers: '/images/guitar-amplifiers-cabinets.jpg',
  keyboards:  '/images/keyboards-synths-and-accessories.jpg',
  percussion: '/images/percussion.jpg',
};

const img = heroImages[category!];
const heroBg = img
  ? `background-image: linear-gradient(rgba(0,0,0,0.52), rgba(0,0,0,0.62)), url('${img}'); background-size: cover; background-position: center;`
  : `background: linear-gradient(160deg, #0a0f08 0%, #161f10 60%, #0a0f08 100%);`;
---

<Layout
  title={cat.name}
  description={`Rent professional ${cat.name.toLowerCase()} in India. ${cat.description}`}
>
  <!-- Hero banner -->
  <div class="cat-hero" style={heroBg}>
    <div class="cat-hero-inner">
      <nav class="hero-breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="hero-bc-link">Home</a>
        <span class="hero-bc-sep">/</span>
        <a href="/equipment" class="hero-bc-link">Rental Equipment</a>
        <span class="hero-bc-sep">/</span>
        <span class="hero-bc-current">{cat.name}</span>
      </nav>
      <h1 class="cat-hero-title">{cat.name.toUpperCase()}</h1>
    </div>
  </div>

  <!-- Items -->
  <div class="page-container">
    {items.length === 0 ? (
      <div class="empty-state">
        <h2 class="display-sm">Coming soon.</h2>
        <p style="color: var(--color-body); margin: 0 0 20px;">Contact us for current availability.</p>
        <a href="/contact" class="btn-primary">Ask about availability</a>
      </div>
    ) : (
      <>
        <div class="brands-container">
          {brands.map(brand => (
            <div class="brand-section">
              <div class="brand-header">
                <h2 class="brand-title">{brand}</h2>
                <span class="brand-rule"></span>
              </div>
              <div class="items-grid">
                {brandGroups[brand].map(item => {
                  const preview = item.included.slice(0, 4).join(' • ');
                  const hasMore = item.included.length > 4;
                  return (
                    <div class="item-card">
                      <a href={`/equipment/${item.category}/${item.slug}`} class="card-img-link">
                        <div class="card-img">
                          {item.image ? (
                            <img src={item.image} alt={item.name} loading="lazy" class="card-photo" />
                          ) : (
                            <div class="card-img-placeholder">
                              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.15">
                                <path d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/>
                              </svg>
                            </div>
                          )}
                          {item.featured && <span class="card-badge">Popular</span>}
                        </div>
                      </a>
                      <div class="card-body">
                        <a href={`/equipment/${item.category}/${item.slug}`} class="card-name-link">
                          <h3 class="card-name">{item.name}</h3>
                        </a>
                        <p class="card-price">₹{item.pricePerDay.toLocaleString('en-IN')}<span class="card-price-unit">/day</span></p>
                        {item.included.length > 0 && (
                          <p class="card-preview">• {preview}{hasMore ? '…' : ''}</p>
                        )}
                        <a href={`/equipment/${item.category}/${item.slug}`} class="see-details-btn">
                          See Details
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                        </a>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>

        {isDrums && cymbalItems.length > 0 && (
          <div class="cymbal-section">
            <div class="brand-header">
              <h2 class="brand-title">Cymbals</h2>
              <span class="brand-rule"></span>
            </div>
            <div class="items-grid">
              {cymbalItems.map(item => {
                const preview = item.included.slice(0, 4).join(' • ');
                const hasMore = item.included.length > 4;
                return (
                  <div class="item-card">
                    <a href={`/equipment/${item.category}/${item.slug}`} class="card-img-link">
                      <div class="card-img">
                        <div class="card-img-placeholder">
                          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.15">
                            <path d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/>
                          </svg>
                        </div>
                      </div>
                    </a>
                    <div class="card-body">
                      <a href={`/equipment/${item.category}/${item.slug}`} class="card-name-link">
                        <h3 class="card-name">{item.name}</h3>
                      </a>
                      <p class="card-price">₹{item.pricePerDay.toLocaleString('en-IN')}<span class="card-price-unit">/day</span></p>
                      {item.included.length > 0 && (
                        <p class="card-preview">• {preview}{hasMore ? '…' : ''}</p>
                      )}
                      <a href={`/equipment/${item.category}/${item.slug}`} class="see-details-btn">
                        See Details
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                      </a>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </>
    )}
  </div>
</Layout>

<style>
  /* Hero */
  .cat-hero { padding: 72px 0 80px; background-color: #111; }
  .cat-hero-inner { max-width: 1280px; margin: 0 auto; padding: 0 32px; }
  .hero-breadcrumb { display: flex; align-items: center; gap: 8px; margin-bottom: 28px; }
  .hero-bc-link { font-size: 12px; color: rgba(255,255,255,0.35); text-decoration: none; transition: color 0.12s; }
  .hero-bc-link:hover { color: rgba(255,255,255,0.6); }
  .hero-bc-sep { font-size: 12px; color: rgba(255,255,255,0.18); }
  .hero-bc-current { font-size: 12px; color: rgba(255,255,255,0.45); }
  .cat-hero-title {
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1;
    margin: 0;
    text-shadow: 0 2px 24px rgba(0,0,0,0.4);
  }

  /* Content */
  .page-container { max-width: 1280px; margin: 0 auto; padding: 56px 32px 80px; }
  .brands-container { display: flex; flex-direction: column; gap: 64px; }

  /* Brand section */
  .brand-section {}
  .cymbal-section { margin-top: 64px; }
  .brand-header {
    display: flex; align-items: center; gap: 24px;
    margin-bottom: 28px;
  }
  .brand-title {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 36px);
    font-weight: 700;
    color: var(--color-ink);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .brand-rule { flex: 1; height: 1px; background-color: rgba(255,255,255,0.12); }

  /* Grid */
  .items-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

  /* Card */
  .item-card {
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: 8px;
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.15s;
  }
  .item-card:hover {
    border-color: var(--color-hairline-strong);
    box-shadow: 0 6px 24px rgba(0,0,0,0.30);
    transform: translateY(-2px);
  }

  /* Card image */
  .card-img-link { display: block; }
  .card-img {
    background-color: var(--color-canvas-soft-2);
    aspect-ratio: 4/3;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; position: relative;
  }
  .card-photo { width: 100%; height: 100%; object-fit: cover; }
  .card-img-placeholder { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; }
  .card-badge {
    position: absolute; top: 10px; left: 10px;
    background: var(--color-canvas-soft-2); color: var(--color-ink);
    border: 1px solid var(--color-hairline-strong);
    font-size: 10px; font-weight: 500; padding: 2px 8px;
    border-radius: 99px; letter-spacing: 0.03em;
  }

  /* Card body */
  .card-body { padding: 16px 18px 18px; display: flex; flex-direction: column; flex: 1; }
  .card-name-link { text-decoration: none; }
  .card-name {
    font-size: 15px; font-weight: 700; color: var(--color-ink);
    margin: 0 0 4px; line-height: 1.3;
    transition: color 0.12s;
  }
  .card-name-link:hover .card-name { color: #1a8fa8; }
  .card-price {
    font-size: 14px; font-weight: 600; color: var(--color-ink);
    margin: 0 0 8px;
  }
  .card-price-unit { font-size: 12px; font-weight: 400; color: var(--color-mute); margin-left: 2px; }
  .card-preview {
    font-size: 12px; color: var(--color-body); line-height: 1.5; margin: 0 0 14px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* See Details button */
  .see-details-btn {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 8px 18px;
    background-color: #1a8fa8; color: #fff;
    font-size: 13px; font-weight: 500;
    border-radius: 4px; text-decoration: none;
    margin-top: auto;
    width: fit-content;
    transition: background-color 0.15s;
  }
  .see-details-btn:hover { background-color: #157d94; }

  /* Empty */
  .empty-state {
    padding: 80px 0; text-align: center;
    display: flex; flex-direction: column; align-items: center;
  }

  @media (max-width: 1024px) { .items-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) {
    .cat-hero { padding: 48px 0 56px; }
    .cat-hero-inner { padding: 0 20px; }
    .page-container { padding: 40px 20px 60px; }
    .items-grid { grid-template-columns: 1fr; gap: 16px; }
  }
</style>
