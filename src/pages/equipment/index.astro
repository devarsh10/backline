---
import Layout from '../../layouts/Layout.astro';
import EquipmentCard from '../../components/EquipmentCard.astro';
import { equipment } from '../../data/equipment';
---

<Layout
  title="Equipment"
  description="Browse professional music gear for rent. Drums, guitars, amplifiers, keyboards, and accessories. Transparent pricing, no account needed."
>
  <div class="page-container">
    <div class="page-header">
      <div class="breadcrumb">
        <a href="/" class="breadcrumb-link">Home</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <span class="breadcrumb-current">Equipment</span>
      </div>
      <h1 class="display-lg page-title">Equipment</h1>
      <p class="page-sub">Browse our catalog. Add what you need to your cart and checkout.</p>
    </div>

    <div class="equipment-grid">
      {equipment.filter(e => e.available).map(item => (
        <EquipmentCard item={item} />
      ))}
    </div>
  </div>
</Layout>

<style>
  .page-container { max-width: 1280px; margin: 0 auto; padding: 0 24px 80px; }
  .page-header { padding: 40px 0 32px; }
  .breadcrumb { display: flex; align-items: center; gap: 6px; margin-bottom: 14px; }
  .breadcrumb-link { font-size: 13px; color: var(--color-mute); text-decoration: none; }
  .breadcrumb-link:hover { color: var(--color-body); }
  .breadcrumb-sep { font-size: 13px; color: var(--color-hairline-strong); }
  .breadcrumb-current { font-size: 13px; color: var(--color-body); }
  .page-title { margin: 0 0 8px; }
  .page-sub { font-size: 15px; color: var(--color-body); margin: 0; }

  .equipment-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }

  @media (max-width: 1100px) { .equipment-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 768px) { .equipment-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) {
    .page-container { padding: 0 16px 60px; }
    .equipment-grid { grid-template-columns: 1fr; }
  }
</style>
