---
import Layout from '../layouts/Layout.astro';
import EquipmentCard from '../components/EquipmentCard.astro';
import { categories, getFeaturedEquipment } from '../data/equipment';

const featured = getFeaturedEquipment();
---

<Layout
  title="Music Gear Rental in India"
  description="Rent professional amplifiers, drums, keyboards, PA systems, and more for concerts, events, and studios across India. Transparent pricing, no account required."
>
  <!-- ── Hero ── -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-badge">
        <span class="caption-mono">India's premium gear rental</span>
      </div>
      <h1 class="display-xl hero-headline">
        Professional music gear,<br />
        <span class="amply-gradient-text">ready when you play.</span>
      </h1>
      <p class="body-lg hero-sub">
        Rent amplifiers, drums, keyboards, PA systems, and full stage rigs for concerts, events, and studios. Transparent pricing, no hidden costs.
      </p>
      <div class="hero-cta-row">
        <a href="/equipment" class="btn-primary">Browse Equipment</a>
      </div>
      <div class="hero-trust-row">
        <span class="hero-trust-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          No account needed
        </span>
        <span class="hero-trust-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Prices shown upfront
        </span>
        <span class="hero-trust-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Professional crew delivers &amp; sets up
        </span>
        <span class="hero-trust-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Plug &amp; play when you arrive
        </span>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="hero-scroll-hint" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
    </div>
  </section>

  <!-- ── Categories ── -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="caption-mono section-eyebrow">Browse by category</span>
        <h2 class="display-lg section-title">Everything you need on stage.</h2>
        <p class="body-lg section-sub">From a single DI box to a full festival backline — we stock the gear professionals trust.</p>
      </div>

      <div class="category-grid">
        {categories.map((cat) => (
          <a href={`/equipment/${cat.slug}`} class="category-card">
            <span class="category-icon" aria-hidden="true">{cat.icon}</span>
            <div>
              <h3 class="category-card-name">{cat.name}</h3>
              <p class="category-card-desc">{cat.description}</p>
            </div>
            <span class="category-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Featured gear ── -->
  <section class="section section-soft">
    <div class="container">
      <div class="section-header">
        <span class="caption-mono section-eyebrow">Popular rentals</span>
        <h2 class="display-lg section-title">Gear musicians love.</h2>
        <p class="body-lg section-sub">Our most-rented items, maintained to touring standard before every rental.</p>
      </div>

      <div class="gear-grid">
        {featured.map((item) => (
          <EquipmentCard item={item} />
        ))}
      </div>

      <div style="text-align: center; margin-top: 40px;">
        <a href="/equipment" class="btn-secondary">View all equipment →</a>
      </div>
    </div>
  </section>

  <!-- ── How it works ── -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="caption-mono section-eyebrow">The rental process</span>
        <h2 class="display-lg section-title">Simple. Transparent. Fast.</h2>
        <p class="body-lg section-sub">Browse, add to cart, check out. We handle everything else — including setup at your venue.</p>
      </div>

      <div class="process-grid">
        <div class="process-step">
          <div class="process-number">01</div>
          <div class="process-content">
            <h3 class="process-step-title">Browse &amp; add to cart</h3>
            <p class="process-step-desc">Explore our catalog. Add drums, amps, accessories — whatever your event needs — to your cart.</p>
          </div>
        </div>
        <div class="process-connector" aria-hidden="true"></div>
        <div class="process-step">
          <div class="process-number">02</div>
          <div class="process-content">
            <h3 class="process-step-title">Checkout</h3>
            <p class="process-step-desc">Pick your rental dates, enter your details, and place the order. Multi-day discounts applied automatically.</p>
          </div>
        </div>
        <div class="process-connector" aria-hidden="true"></div>
        <div class="process-step">
          <div class="process-number">03</div>
          <div class="process-content">
            <h3 class="process-step-title">Confirm &amp; pay</h3>
            <p class="process-step-desc">We confirm your booking within 2 hours and share UPI / bank transfer details for payment.</p>
          </div>
        </div>
        <div class="process-connector" aria-hidden="true"></div>
        <div class="process-step">
          <div class="process-number">04</div>
          <div class="process-content">
            <h3 class="process-step-title">Deliver, setup &amp; play</h3>
            <p class="process-step-desc">Our crew delivers, sets everything up at your venue, and tests all lines. Arrive and plug in.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── CTA band ── -->
  <section class="section cta-band">
    <div class="container">
      <div class="cta-band-inner">
        <div>
          <h2 class="display-md cta-band-title">Not sure what gear you need?</h2>
          <p class="body-lg cta-band-sub">Tell us your event type and lineup — we'll suggest the right package. Or just browse and build your cart — it only takes a few minutes.</p>
        </div>
        <div class="cta-band-actions">
          <a href="/equipment" class="btn-primary">Browse equipment</a>
          <a href="/contact" class="btn-secondary">Talk to us</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero — full viewport height ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex; align-items: center;
    overflow: hidden;
    background-color: #111;
    background-image: linear-gradient(rgba(0,0,0,0.50), rgba(0,0,0,0.60)), url('/images/website-home-screen.png');
    background-size: cover;
    background-position: center;
  }
  .hero-bg { display: none; }
  .hero-inner {
    position: relative; width: 100%;
    display: flex; flex-direction: column;
    align-items: center; text-align: center;
    padding: 100px 0 80px;
  }
  .hero-badge {
    background-color: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.20);
    border-radius: var(--radius-full);
    padding: 4px 14px; margin-bottom: 24px; display: inline-flex;
  }
  .hero-badge .caption-mono { color: rgba(255,255,255,0.70); }
  .hero-headline { max-width: 800px; margin: 0 0 20px 0; color: #fff; }
  .hero-sub { color: rgba(255,255,255,0.75); max-width: 560px; margin: 0 0 32px 0; }
  .hero-cta-row { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; margin-bottom: 28px; }
  .hero-trust-row { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
  .hero-trust-item {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 13px; font-weight: 500; color: #ffffff;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.20);
    border-radius: 999px;
    padding: 6px 14px;
    backdrop-filter: blur(4px);
  }
  .hero-trust-item svg { color: #4dd4e8; flex-shrink: 0; }
  .hero-cta-row .btn-secondary {
    border-color: rgba(255,255,255,0.35); color: #fff; background: transparent;
  }
  .hero-cta-row .btn-secondary:hover { background-color: rgba(255,255,255,0.10); border-color: rgba(255,255,255,0.55); }

  /* Scroll hint arrow at the bottom of hero */
  .hero-scroll-hint {
    position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    color: rgba(255,255,255,0.35); font-size: 11px; letter-spacing: 0.06em;
    text-transform: uppercase; animation: bounce 2s ease-in-out infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(5px); }
  }

  /* ── Rest of page — back to light ── */
  .section { padding: 80px 0; }
  .section-soft { background-color: var(--color-canvas-soft); }
  .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
  .section-header { text-align: center; margin-bottom: 48px; }
  .section-eyebrow { color: var(--color-mute); display: block; margin-bottom: 10px; }
  .section-title { margin: 0 0 14px 0; }
  .section-sub { color: var(--color-body); max-width: 520px; margin: 0 auto; }

  .category-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .category-card {
    display: flex; flex-direction: column; gap: 10px; padding: 20px;
    background-color: var(--color-canvas); border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md); text-decoration: none; color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.12s;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
  }
  .category-card:hover {
    border-color: var(--color-hairline-strong);
    box-shadow: 0 4px 16px -4px rgba(0,0,0,0.10);
    transform: translateY(-1px);
  }
  .category-icon { font-size: 22px; line-height: 1; }
  .category-card-name { font-size: 15px; font-weight: 600; color: var(--color-ink); letter-spacing: -0.02em; margin: 0 0 4px 0; }
  .category-card-desc { font-size: 12px; color: var(--color-body); line-height: 1.5; margin: 0; }
  .category-arrow { margin-top: auto; font-size: 14px; color: var(--color-mute); transition: color 0.12s, transform 0.12s; }
  .category-card:hover .category-arrow { color: var(--color-ink); transform: translateX(3px); }

  .gear-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }

  .process-grid {
    display: grid; grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    align-items: start; gap: 0; max-width: 900px; margin: 0 auto;
  }
  .process-step { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 12px; }
  .process-number {
    font-family: var(--font-mono); font-size: 11px; color: var(--color-mute);
    width: 34px; height: 34px;
    border: 1px solid var(--color-hairline); border-radius: var(--radius-full);
    display: flex; align-items: center; justify-content: center;
    background-color: var(--color-canvas); flex-shrink: 0;
  }
  .process-content { max-width: 190px; }
  .process-step-title { font-size: 14px; font-weight: 600; color: var(--color-ink); letter-spacing: -0.02em; margin: 0 0 6px 0; }
  .process-step-desc { font-size: 13px; color: var(--color-body); line-height: 1.55; margin: 0; }
  .process-connector { width: 32px; height: 1px; background-color: var(--color-hairline); margin-top: 17px; flex-shrink: 0; }

  .cta-band { background-color: var(--color-canvas-soft); border-top: 1px solid var(--color-hairline); }
  .cta-band-inner { display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }
  .cta-band-title { margin: 0 0 8px 0; }
  .cta-band-sub { color: var(--color-body); margin: 0; max-width: 480px; }
  .cta-band-actions { display: flex; gap: 10px; flex-shrink: 0; flex-wrap: wrap; }

  @media (max-width: 1024px) {
    .category-grid { grid-template-columns: repeat(3, 1fr); }
    .gear-grid { grid-template-columns: repeat(2, 1fr); }
    .process-grid { grid-template-columns: 1fr; gap: 24px; max-width: 500px; }
    .process-connector { display: none; }
    .process-step { flex-direction: row; text-align: left; align-items: flex-start; }
    .process-content { max-width: none; }
  }
  @media (max-width: 640px) {
    .category-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
    .gear-grid { grid-template-columns: 1fr; }
    .cta-band-inner { flex-direction: column; align-items: flex-start; }
    .container { padding: 0 16px; }
    .section { padding: 56px 0; }
    .section-header { margin-bottom: 32px; }
  }
</style>
